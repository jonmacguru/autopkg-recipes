<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Builds the Claude Desktop PKG, uploads it to Jamf Pro, and creates/updates a Self Service policy with the extracted app icon.</string>
    <key>Identifier</key>
    <string>jonmacguru.recipes.jamf.ClaudeDesktop</string>
    <key>Input</key>
    <dict>
        <key>NAME</key>
        <string>Claude Desktop</string>
        <key>CATEGORY</key>
        <string>Testing</string>
        <key>POLICY_CATEGORY</key>
        <string>Applications</string>
        <key>POLICY_NAME</key>
        <string>Install Latest %NAME%</string>
        <key>SELF_SERVICE_DISPLAY_NAME</key>
        <string>%NAME%</string>
        <key>SELF_SERVICE_DESCRIPTION</key>
        <string>Installs or reinstalls %NAME% from Self Service.</string>
        <key>POLICY_TEMPLATE</key>
        <string>%RECIPE_DIR%/JamfPolicyTemplate-noSS.xml</string>
    </dict>
    <key>MinimumVersion</key>
    <string>2.3</string>
    <key>ParentRecipe</key>
    <string>jonmacguru.recipes.pkg.ClaudeDesktop</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>com.github.grahampugh.jamf-upload.processors/JamfPackageUploader</string>
            <key>Arguments</key>
            <dict>
                <key>pkg_category</key>
                <string>%CATEGORY%</string>
                <key>pkg_path</key>
                <string>%pkg_path%</string>
            </dict>
        </dict>
        <dict>
            <key>Processor</key>
            <string>StopProcessingIf</string>
            <key>Arguments</key>
            <dict>
                <key>predicate</key>
                <string>pkg_uploaded == True</string>
            </dict>
        </dict>
        <dict>
            <key>Processor</key>
            <string>com.github.grahampugh.jamf-upload.processors/JamfPolicyUploader</string>
            <key>Arguments</key>
            <dict>
                <key>policy_name</key>
                <string>%POLICY_NAME%</string>
                <key>policy_template</key>
                <string>%RECIPE_DIR%/%POLICY_TEMPLATE%</string>
                <key>icon</key>
                <string>%app_icon_path%</string>
                <key>replace_icon</key>
                <string>True</string>
                <key>replace_policy</key>
				<true/>
            </dict>
        </dict>
    </array>
</dict>
</plist>
