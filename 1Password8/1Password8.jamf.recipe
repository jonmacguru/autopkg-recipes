<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest 1Password for Mac PKG, creates a versioned copy, and uploads it to Jamf Pro.</string>
	<key>Identifier</key>
	<string>jonmacguru-recipes.jamf.1Password8</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>1Password</string>
		<key>CATEGORY</key>
		<string>Productivity</string>
		<key>MinimumVersion</key>
		<string>2.3</string>
	</dict>
	<key>ParentRecipe</key>
	<string>jonmacguru-recipes.pkg.1Password8</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>JamfPackageUploader</string>
			<key>Arguments</key>
			<dict>
				<key>pkg_category</key>
				<string>%CATEGORY%</string>
				<key>pkg_path</key>
				<string>%pkg_path%</string>
				<key>pkg_name</key>
				<string>%NAME%-%version%</string>
				<key>replace_pkg</key>
				<string>True</string>
			</dict>
		</dict>
	</array>
</dict>
</plist>
