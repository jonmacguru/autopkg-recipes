<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest 1Password for Mac PKG, fully expands it with pkgutil, reads the app version, and creates a versioned copy of the vendor PKG.</string>
	<key>Identifier</key>
	<string>jonmacguru-recipes.pkg.1Password8</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>1Password</string>
		<key>APP_PATH</key>
		<string>Applications/1Password.app</string>
		<key>MinimumVersion</key>
		<string>2.3</string>
	</dict>
	<key>ParentRecipe</key>
	<string>jonmacguru-recipes.download.1Password8</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>FileCreator</string>
			<key>Arguments</key>
			<dict>
				<key>file_path</key>
				<string>%RECIPE_CACHE_DIR%/expand_1password_pkg.sh</string>
				<key>file_mode</key>
				<string>0755</string>
				<key>file_content</key>
				<string>#!/bin/zsh
set -euo pipefail
rm -rf "%RECIPE_CACHE_DIR%/expanded-full"
/usr/sbin/pkgutil --expand-full "%pathname%" "%RECIPE_CACHE_DIR%/expanded-full"
</string>
			</dict>
		</dict>
		<dict>
	<key>Processor</key>
	<string>RunShellScript</string>
	<key>Arguments</key>
	<dict>
		<key>script_path</key>
		<string>%RECIPE_CACHE_DIR%/expand_1password_pkg.sh</string>
	</dict>
</dict>
		<dict>
			<key>Processor</key>
			<string>PlistReader</string>
			<key>Arguments</key>
			<dict>
				<key>info_path</key>
				<string>%RECIPE_CACHE_DIR%/expanded-full/%APP_PATH%/Contents/Info.plist</string>
				<key>plist_keys</key>
				<dict>
					<key>CFBundleShortVersionString</key>
					<string>version</string>
					<key>CFBundleVersion</key>
					<string>build</string>
					<key>LSMinimumSystemVersion</key>
					<string>min_os_version</string>
				</dict>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PkgCopier</string>
			<key>Arguments</key>
			<dict>
				<key>source_pkg</key>
				<string>%pathname%</string>
				<key>pkg_path</key>
				<string>%RECIPE_CACHE_DIR%/%NAME%-%version%.pkg</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PathDeleter</string>
			<key>Arguments</key>
			<dict>
				<key>path_list</key>
				<array>
					<string>%RECIPE_CACHE_DIR%/expanded-full</string>
					<string>%RECIPE_CACHE_DIR%/expand_1password_pkg.sh</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
