<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Builds a package for 1Password and uploads it to Jamf Pro.</string>
    <key>Identifier</key>
    <string>jonmacguru-recipes.jamf.1Password-pkg-upload</string>
    <key>Input</key>
    <dict>
        <key>NAME</key>
        <string>1Password</string>
        <key>JSS_INVENTORY_NAME</key>
        <string>%NAME%</string>
        <key>POLICY_CATEGORY</key>
        <string>Productivity</string>
        <key>POLICY_TEMPLATE</key>
        <string>Install Latest %NAME%</string>
    </dict>
    <key>MinimumVersion</key>
    <string>2.3</string>
    <key>ParentRecipe</key>
    <string>jonmacguru-recipes.pkg.1Password</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>com.github.grahampugh.jamf-upload.processors/JamfPackageUploader</string>
            <key>Arguments</key>
            <dict>
                <key>pkg_path</key>
                <string>%pkg_path%</string>
                <key>pkg_name</key>
                <string>%NAME%-%DOWNLOAD_BUILD%-%DOWNLOAD_ARCH%-%version%</string>
                <key>category</key>
                <string>%POLICY_CATEGORY%</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
